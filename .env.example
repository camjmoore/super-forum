# Node environment
NODE_ENV=development

# Server port
PORT=4000

# PostgreSQL configuration
PG_HOST=postgres
PG_PORT=5432
PG_ACCOUNT=forum_user
PG_PASSWORD=forum_password
PG_DATABASE=super_duper_forum
PG_SYNCHRONIZE=true
PG_LOGGING=true

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Session configuration
COOKIE_NAME=SESSIONID
SESSION_SECRET=dev_secret_key_change_in_production

# Email configuration (for future email verification feature)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=your_email_service_key
# SMTP_PASS=your_password
# EMAIL_FROM=noreply@yourdomain.com
